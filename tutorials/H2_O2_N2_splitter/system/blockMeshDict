FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Splitter-plate mixing layer: 15 mm x 5 mm x 0.2 mm (2D)
//
// Two blocks stacked in y, sharing a mid-plane at y=2.5 mm:
//   lower (y = 0..2.5 mm) : H2 stream
//   upper (y = 2.5..5 mm) : Air stream
//
// 190 x 60 x 1 cells per block.
// x: graded ~20 um at inlet (x=0) → ~200 um at outlet (x=15 mm), R=10, r=1.0123.
// y: graded ~10 um at centre (y=2.5 mm) → ~109 um at top/bottom, R=10.9, r=1.0413.
//
// Inlet conditions (left face, x=0):
//   Air  (y=2.5-5 mm): M=2.5, T=1500K, p=101325 Pa
//          c = sqrt(gamma*R_mix*T) = sqrt(1.310 * 288.2 * 1500) = 753 m/s
//          U = 2.5 * 753 = 1882 m/s
//   Fuel (y=0-2.5 mm): M=1.5, T=350K, p=101325 Pa
//          c = sqrt(gamma*R_H2*T)  = sqrt(1.402 * 4123 * 350) = 1422 m/s
//          U = 1.5 * 1422 = 2133 m/s
//
// Outlet: right face (x=15 mm) + top (y=5 mm) + bottom (y=0 mm).
// Top and bottom are open outflow boundaries so the mixing layer
// can spread freely in y without being constrained by walls.

convertToMeters 0.001;   // all coordinates in mm

vertices
(
    //  back plane (z = -0.1 mm)
    (  0    0    -0.1)   // v0
    ( 15    0    -0.1)   // v1
    ( 15    2.5  -0.1)   // v2
    (  0    2.5  -0.1)   // v3
    (  0    5    -0.1)   // v4
    ( 15    5    -0.1)   // v5

    //  front plane (z = +0.1 mm)
    (  0    0     0.1)   // v6
    ( 15    0     0.1)   // v7
    ( 15    2.5   0.1)   // v8
    (  0    2.5   0.1)   // v9
    (  0    5     0.1)   // v10
    ( 15    5     0.1)   // v11
);

blocks
(
    // Lower block  (H2 stream, y = 0..2.5 mm)
    //   190 x 60 x 1 cells.
    //   x: 20 um at x=0 → 200 um at x=15 mm  (R=10, r=1.0123).
    //   y: 109 um at y=0 → 10 um at y=2.5 mm  (R=1/10.9≈0.092, r=1.0413).
    hex (0 1 2 3 6 7 8 9)   (190 60 1)  simpleGrading (10 0.0917 1)

    // Upper block  (Air stream, y = 2.5..5 mm)
    //   x: same grading as lower block.
    //   y: 10 um at y=2.5 mm → 109 um at y=5 mm  (R=10.9, r=1.0413).
    hex (3 2 5 4 9 8 11 10) (190 60 1)  simpleGrading (10 10.9 1)
);

edges
(
);

boundary
(
    inletFuel
    {
        type patch;
        faces
        (
            (0 6 9 3)   // left face of lower block
        );
    }

    inletAir
    {
        type patch;
        faces
        (
            (3 9 10 4)  // left face of upper block
        );
    }

    outlet
    {
        type patch;
        faces
        (
            (1 2 8 7)   // right face of lower block
            (2 5 11 8)  // right face of upper block
        );
    }

    bottom
    {
        type patch;
        faces
        (
            (0 1 7 6)   // y = 0 face of lower block
        );
    }

    top
    {
        type patch;
        faces
        (
            (4 10 11 5) // y = 5 mm face of upper block
        );
    }

    frontAndBack
    {
        type empty;
        faces
        (
            (0 3 2 1)   // z = -0.1 mm, lower block
            (3 4 5 2)   // z = -0.1 mm, upper block
            (6 7 8 9)   // z = +0.1 mm, lower block
            (9 8 11 10) // z = +0.1 mm, upper block
        );
    }
);

mergePatchPairs
(
);

