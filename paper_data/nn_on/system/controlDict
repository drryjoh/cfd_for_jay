FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Minimal controlDict for foamToVTK post-processing only.
// Not for running a solver.

application     foamToVTK;

startFrom       latestTime;
startTime       0;

stopAt          endTime;
endTime         0.000664;

deltaT          1;

writeFormat     ascii;
writePrecision  12;
writeCompression off;

timeFormat      general;
timePrecision   12;

runTimeModifiable false;

// ************************************************************************* //
